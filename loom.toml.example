# loom.toml — Loom configuration file
# Copy this file to loom.toml and fill in your values.
# API keys go in .env (never in this file).

# ─────────────────────────────────────────────
# Basic metadata
# ─────────────────────────────────────────────

[loom]
name = "loom"
version = "0.1.0"

# ─────────────────────────────────────────────
# Identity / Prompt Stack
# ─────────────────────────────────────────────
# Three-layer prompt composition:
#   SOUL.md       — global identity, always in context
#   Agent.md      — project / environment context, agent can edit
#   personality   — temporary cognitive lens (leave blank to disable)

[identity]
soul        = "SOUL.md"
agent       = "Agent.md"
personality = ""
# Example: personality = "personalities/adversarial.md"

# ─────────────────────────────────────────────
# Cognition
# ─────────────────────────────────────────────
# default_model is used by all entrypoints when no --model flag is given.
#
# Supported prefixes:
#   MiniMax-*         → MiniMax via Anthropic-compatible endpoint  (MINIMAX_API_KEY in .env)
#   claude-*          → Anthropic provider                         (ANTHROPIC_API_KEY in .env)
#   ollama/<name>     → local Ollama server  (enable [providers.ollama] below)
#   lmstudio/<name>   → local LM Studio      (enable [providers.lmstudio] below)

[cognition]
default_model = "claude-sonnet-4-6"
max_tokens    = 8096

# Output-token cap for the main stream_turn() LLM call. Different providers
# have wildly different ceilings — MiniMax-M2.7 supports ~64K, Claude Sonnet
# 4.6 supports ~64K, small local models often 4-8K. Set a conservative
# session-wide default and override per-model below.
output_max_tokens = 32768

# Per-model overrides (table key = exact model name). Entries here win over
# the default above. Unknown models fall through to output_max_tokens.
[cognition.output_max_tokens_overrides]
"MiniMax-M2.7"       = 65536
"claude-sonnet-4-6"  = 65536
"claude-opus-4-7"    = 32768

# ─────────────────────────────────────────────
# Local providers
# ─────────────────────────────────────────────
# Enable Ollama or LM Studio without any API key.
# base_url defaults shown below; override if you run on a different port.
# You can also set OLLAMA_BASE_URL / LMSTUDIO_BASE_URL in .env instead.

# [providers.ollama]
# enabled       = true
# base_url      = "http://localhost:11434/v1"
# default_model = "llama3.2"           # bare model name — no "ollama/" prefix here

# [providers.lmstudio]
# enabled       = true
# base_url      = "http://localhost:1234/v1"
# default_model = "phi-4"              # must match the model loaded in LM Studio

# ─────────────────────────────────────────────
# Memory
# ─────────────────────────────────────────────

[memory]
backend    = "sqlite"
db_path    = "~/.loom/memory.db"

# Episodic entries older than this are eligible for pruning.
episodic_retention_days = 7

# Skills whose EMA confidence drops below this are marked deprecated.
skill_deprecation_threshold = 0.3

# Compress episodic → semantic after this many **uncompressed** entries
# accumulate per session. Already-compressed rows are excluded from the count
# and kept on disk (soft-delete) for audit and recovery — TTL prune eventually
# clears them per ``episodic_retention_days``. The LLM compression pass caps
# at 60 entries per batch, so values above ~55 will silently drop the oldest.
# Lower values keep semantic memory fresher but shrink each batch, which can
# hurt fact-extraction quality. 10 is fine for long-running Discord sessions,
# 30 for short CLI sessions.
episodic_compress_threshold = 30

# ─────────────────────────────────────────────
# Reflection (Issue #120 PR1) — Skill diagnostic layer
# ─────────────────────────────────────────────
# When a skill is activated via ``load_skill`` and the turn completes,
# TaskReflector runs a structured LLM diagnostic over the execution
# trajectory.  The diagnostic produces a ``TaskDiagnostic`` with:
#   - instructions_followed / instructions_violated
#   - failure_patterns / success_patterns
#   - mutation_suggestions      (concrete SKILL.md edit proposals)
#   - task_type                 (closed label set, see task_reflector.py)
#   - quality_score             (1.0-5.0, also drives the confidence EMA)
#
# Diagnostics are written to SemanticMemory under
# ``skill:{name}:diagnostic:{timestamp}`` and can be inspected via
# ``loom diagnostic recent``.  Each platform (CLI / TUI / Discord) also
# renders a lightweight live notification at the ``visibility`` level
# chosen below.

[reflection]
auto_reflect = true
# "off"     — disables diagnostics entirely (no LLM call, no writes)
# "summary" — one-line live notification per diagnostic (default)
# "verbose" — full diagnostic summary + top mutation suggestion
visibility = "summary"

# ─────────────────────────────────────────────
# Skill Mutation + Lifecycle (Issue #120 PR 2 + PR 3)
# ─────────────────────────────────────────────
# After TaskReflector emits a diagnostic, SkillMutator can ask the LLM to
# rewrite the SKILL.md body incorporating the ``mutation_suggestions``.
# The rewrite lands in the ``skill_candidates`` pool (status=generated).
#
# PR 3 adds the lifecycle:
#   generated ──(auto_shadow | manual)──► shadow
#     │                                     │
#     └──────── (deprecate) ────────►  deprecated
#                                           │
#                                       (promote)
#                                           ▼
#                                       promoted
#                                           │
#                                       (rollback)
#                                           ▼
#                                       rolled_back
#
# Shadow candidates are served to a deterministic slice of sessions in
# auto_c mode, so TaskReflector can A/B-compare the two bodies.  Promote
# archives the previous body to ``skill_version_history`` — rollback
# restores from there.  Candidates can be inspected with
# ``loom skill candidates`` and promoted/rolled back via
# ``loom skill promote`` / ``loom skill rollback`` or the matching agent
# tools (``promote_skill_candidate`` / ``rollback_skill``).
#
# Defaults keep mutation OFF so enabling reflection alone does not start
# writing candidate bodies.  Turn it on once you want the candidate pool
# to accumulate.

[mutation]
enabled          = false
# Only propose when the diagnostic quality_score is at or below this ceiling.
# High-quality turns don't need a mutation.  Valid range: 1.0 – 5.0.
quality_ceiling  = 3.5
# Require at least this many mutation_suggestions in the diagnostic before
# firing the rewrite.
min_suggestions  = 1
# Truncate the parent SKILL.md body in the rewrite prompt at this many
# characters to keep the request cheap.
max_body_chars   = 6000

# PR 3 — lifecycle routing
# "off"       — never serve a shadow candidate; lifecycle tools still work.
# "auto_c"    — default.  ``generated`` candidates auto-transition to
#               ``shadow`` when the parent is under-performing; shadow
#               candidates are served to ``shadow_fraction`` of sessions.
# "manual_b"  — candidates stay ``generated`` until an explicit promote
#               call.  Nothing is auto-served.
shadow_mode      = "auto_c"
# Fraction of sessions (0.0–1.0) that see the shadow body in auto_c mode.
# 0.5 keeps A/B evenly split; lower values ease candidates in slowly.
shadow_fraction  = 0.5
# Auto-shadow only fires when the parent SkillGenome.confidence is at or
# below this ceiling (i.e. the parent is actually struggling enough to
# warrant an A/B trial).  Range 0.0–1.0.
auto_shadow_confidence_ceiling = 0.7

# PR 4 — Grader-driven fast-track.  When ``SkillMutator.from_batch_diagnostic``
# (used by the meta-skill-engineer skill) sees ``improvement >= this threshold``,
# the resulting candidate is flagged ``fast_track=True`` so it can be promoted
# directly without the shadow N-wins phase.  Range 0.0–1.0.
fast_track_threshold = 0.20

# ─────────────────────────────────────────────
# Telemetry (Issue #142) — Agent self-observability
# ─────────────────────────────────────────────
# The agent tracks three dimensions of its own behavior:
#   tool_call          — per-tool success rate + latency
#   context_layout     — token share across SOUL / Agent / messages layers
#   memory_compression — episodic → semantic fact-yield ratio
#
# Counters live in-memory; snapshots persist to the ``agent_telemetry``
# table every ``persist_interval`` tool calls AND at session stop.
# Anomaly alerts are injected at turn boundaries only when a dimension
# actually reports trouble — the agent is not flooded with normal status.
# The ``agent_health`` tool lets the agent pull state on demand.

[telemetry]
enabled          = true
persist_interval = 100            # flush every N hot-path events
retention_days   = 30             # reserved for future decay — not yet active

# Subset the default dimension set if you want a lighter-weight install.
# Leave unset to enable all three.
# dimensions = ["tool_call", "context_layout", "memory_compression"]

# ─────────────────────────────────────────────
# Session
# ─────────────────────────────────────────────

[session]
# Issue #28: Predictive memory pre-fetcher.
# When enabled, _dispatch_parallel() runs a lightweight MemorySearch query
# before each parallel tool batch and injects top results as an ephemeral
# system message so the LLM has "déjà vu" context for the upcoming tools.
# The ephemeral message is removed after tool execution — history stays clean.
#
# Recommended: keep off until you have substantial semantic memory.
# Performance cost: one extra DB query per parallel tool batch.
prefetch_enabled = false
prefetch_top_n   = 3       # number of memory hits to inject (keep small)

# ─────────────────────────────────────────────
# Timezone  (Issue #124)
# ─────────────────────────────────────────────

[timezone]
# user     — IANA timezone name for all timestamps injected into LLM prompts
#            and user-facing messages (stream_turn, resume_with, sub-agent).
#            Any IANA name is accepted, e.g. "Asia/Taipei", "America/New_York",
#            "Europe/Berlin", "UTC".  Falls back to UTC if this key is absent.
user     = "Asia/Taipei"

# internal — timezone for system-level timestamps: cron scheduling, DB writes,
#            and log entries.  Recommended to keep at "UTC" for portability.
internal = "UTC"

# ─────────────────────────────────────────────
# Harness
# ─────────────────────────────────────────────

[harness]
default_trust_level = "guarded"   # "safe" | "guarded" | "critical"
require_audit_log   = true

# ── Context management (Issue #197) ──────────────────────────────────────────
#
# Just-in-time retrieval: when a tool's output exceeds this token budget,
# the harness automatically writes the full content to the session
# scratchpad and replaces the inline output with a structured reference.
# The agent can then either re-call the tool for fresh data or read the
# scratchpad ref for cached content.
#
# Tokens are estimated as len(output) // 4 (≈ char-to-token ratio for most
# real-world tool outputs). Rough estimate is sufficient — a 30% error has
# no practical effect on whether content is spilled.
#
# Tools whose purpose is content retrieval (task_read, scratchpad_read,
# list_dir, memorize, task_done) are marked inline_only and bypass JIT.
#
# Recommended values:
#   2000 (default) — most tool outputs stay inline; large fetches/reads spill
#    500           — aggressive spilling for very long sessions
#       0           — disables JIT entirely
jit_spill_threshold_tokens = 2000  # internally × 4 → 8000-char threshold

# ── Observation masking (Issue #197 Phase 2) ─────────────────────────────────
#
# At the start of each turn, fold tool outputs older than N turns into
# scratchpad references when the same tool has been called more recently
# (supersession). Masked entries are never lost — full content stays in
# scratchpad, accessible via scratchpad_read or by re-calling the tool.
#
# Folding triggers ONLY when both conditions hold:
#   - age >= mask_age_turns
#   - tool was called more recently (supersession)
# A tool called once stays inline forever. A tool's most-recent call
# always stays inline. Active research data is naturally preserved.
#
# Tuning:
#   20 (default) — deep-research tasks (multi-step fetch_url / web_search
#                   collection feeding synthesis); errs on preserving context
#    7-10        — operational tasks (debug loops, file edits)
#       0        — disables masking; relies entirely on JIT for token mgmt
mask_age_turns = 20

# When true, confines run_bash to the workspace root (cwd=workspace).
# File I/O tools (read_file, write_file, list_dir) always enforce workspace
# boundaries regardless of this setting.
#
# Recommended workflow: set strict_sandbox = true, then use /auto in-session
# to pre-authorize run_bash for the session.  In this mode:
#   - Relative-path shell commands execute without per-call confirmation
#   - Absolute paths that escape the workspace (e.g. /etc, C:\Windows)
#     are detected and still trigger a confirmation prompt
#   - /auto off (or session end) reverts to per-call confirmation
#
# Does not prevent OS-level container escapes — for full isolation use Docker.
strict_sandbox = false

# ─────────────────────────────────────────────
# Autonomy Engine
# ─────────────────────────────────────────────
# Cron expressions use standard 5-field syntax:
#   minute  hour  day-of-month  month  day-of-week
# Day-of-week: 0=Sun, 1=Mon … 6=Sat  (same as standard cron)
#
# ── Unified Pipeline (v0.2.9.4) ──────────────────────────────────────────────
# All execution paths (interactive, MCP, autonomy, sub-agent) flow through
# the same MiddlewarePipeline. A `ToolCall.origin` field drives behavior:
#
#   origin="interactive" / "mcp"    → prompt user on unrecognized tools
#   origin="autonomy" / "subagent"  → DENY if no pre-existing grant
#
# Autonomy schedules can only "spend" pre-authorized grants — they cannot
# request new permissions interactively. You MUST declare what the schedule
# needs via allowed_tools / scope_grants, otherwise GUARDED tool calls will
# be denied silently.
#
# ── How to authorize autonomy schedules ──────────────────────────────────────
#
# 1. allowed_tools — pre-authorize GUARDED tools by name (legacy path).
#    Tools listed here are temporarily authorized for the duration of the
#    schedule's execution, then revoked.
#
#    allowed_tools = ["write_file", "memorize", "run_bash"]
#
# 2. scope_grants — inject scope-level grants for scope-aware tools.
#    Each grant specifies resource/action/selector. These are also temporary
#    and revoked after execution.
#
#    scope_grants = [
#      { resource = "path", action = "write", selector = "news" },
#      { resource = "exec", action = "execute", selector = "workspace" },
#    ]
#
# 3. SAFE tools (read_file, list_dir, recall, load_skill, dream_cycle,
#    memory_prune, etc.) are always pre-authorized — no need to list them.
#
# ── trust_level + notify interaction ─────────────────────────────────────────
#   safe                   → execute immediately, no confirmation
#   guarded + notify=false → execute immediately, no confirmation
#   guarded + notify=true  → Discord Allow/Deny buttons (60 s timeout → skip)
#   critical               → must confirm every time
#
# notify_thread: Discord thread ID to post results into.
#   0 = use the --notify-channel passed to `loom discord start`
#
# ── Quick reference: common GUARDED tools ────────────────────────────────────
#   write_file  — write/create files (MUTATES)
#   memorize    — persist facts to semantic memory (MUTATES)
#   relate      — store relationship triples (MUTATES)
#   run_bash    — execute shell commands (EXEC) — also needs scope_grant
#   web_search  — Brave Search API (NETWORK)
#   spawn_agent — sub-agent (AGENT_SPAN + MUTATES)

[autonomy]
enabled  = false           # set true to activate daemon

# Cron times are always UTC. Convert your local time before filling in.
# Example: Asia/Taipei UTC+8 → subtract 8 h  (09:00 CST = 01:00 UTC)

# ── Example: daily news briefing ──────────────────────────────────────────────
# [[autonomy.schedules]]
# name          = "morning_briefing"
# cron          = "0 1 * * *"        # 01:00 UTC = 09:00 Asia/Taipei
# intent        = "Fetch today's top stories from HackerNews and GitHub trending.
#                  Write a concise briefing to news/YYYY-MM-DD/briefing.md and
#                  store key trends in semantic memory."
# trust_level   = "safe"
# notify        = false
# notify_thread = 0                  # replace with Discord thread ID
# allowed_tools = ["write_file", "memorize"]
# scope_grants  = [
#   { resource = "path", action = "write", selector = "news" },
# ]
# # attach_outputs — globs (relative to workspace) identifying artefacts the
# # agent is expected to produce.  Files matching any pattern whose mtime
# # advanced during the turn are uploaded with the REPORT notification.
# # Discord delivers them natively via discord.File (max 10 per message).
# attach_outputs = ["news/*.md"]

# ── Example: daily journal ────────────────────────────────────────────────────
# [[autonomy.schedules]]
# name          = "daily_journal"
# cron          = "30 9 * * *"       # 09:30 UTC = 17:30 Asia/Taipei
# intent        = "Review today's work: what was done, obstacles encountered,
#                  decisions made. Write to diary/YYYY-MM-DD.md and extract
#                  key facts into semantic memory."
# trust_level   = "safe"
# notify        = false
# notify_thread = 0
# allowed_tools = ["write_file", "memorize"]
# scope_grants  = [
#   { resource = "path", action = "write", selector = "diary" },
# ]

# ── Example: weekday-only task (with Discord confirmation) ────────────────────
# [[autonomy.schedules]]
# name          = "weekly_review"
# cron          = "0 10 * * 5"       # 10:00 UTC = 18:00 Asia/Taipei, Friday
# intent        = "Summarise the week's progress and surface next week's priorities."
# trust_level   = "guarded"
# notify        = true               # will send Discord Allow/Deny buttons
# notify_thread = 0
# allowed_tools = ["write_file", "memorize"]

# ── Example: named event trigger ──────────────────────────────────────────────
# [[autonomy.triggers]]
# name          = "deploy_check"
# event         = "deployment_done"  # fired by: loom autonomy emit deployment_done
# intent        = "Run smoke tests and post results to #deployments channel."
# trust_level   = "guarded"
# notify        = true
# notify_thread = 0
# allowed_tools = ["run_bash"]
# scope_grants  = [
#   { resource = "exec", action = "execute", selector = "workspace" },
# ]

# ── Example: offline dreaming (background knowledge synthesis) ─────────────────
# dream_cycle is a SAFE tool — no allowed_tools needed for it.
# But relate (writing relational triples) is GUARDED.
#
# [[autonomy.schedules]]
# name          = "offline_dreaming"
# cron          = "0 3 * * *"        # 03:00 UTC = 11:00 Asia/Taipei
# intent        = """Run dream_cycle to synthesise insights from semantic memory.
#                    Call the dream_cycle tool with default settings and report
#                    how many new relational insights were written."""
# trust_level   = "safe"
# notify        = false
# notify_thread = 0
# allowed_tools = ["memorize", "relate"]

# ── Example: weekly memory housekeeping ──────────────────────────────────────────
# memory_prune is a SAFE tool — no allowed_tools needed.
#
# [[autonomy.schedules]]
# name          = "memory_housekeeping"
# cron          = "0 19 * * 0"       # 19:00 UTC Sunday = 03:00 Monday Asia/Taipei
# intent        = """Run memory housekeeping. First call memory_prune with
#                    dry_run=true to preview decayed entries. If any qualify,
#                    call again with dry_run=false to delete them. Report:
#                    total examined, pruned, and retained."""
# trust_level   = "safe"
# notify        = false
# notify_thread = 0

# ─────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────
# default_channel is informational; actual routing is determined at runtime
# by which notifiers are registered (CLI, DiscordBotNotifier, etc.)

# ─────────────────────────────────────────────
# Embeddings
# ─────────────────────────────────────────────
# Embeddings
# ─────────────────────────────────────────────
# Two backends selected by the ``provider`` field:
#   "ollama"   — local Ollama server (no API key required)
#   "minimax"  — MiniMax cloud API (requires API key)
#
# OLLAMA example (recommended for local development):
#   [embeddings]
#   provider = "ollama"
#   base_url = "http://localhost:11434"
#   model    = "qwen3-embedding:0.6b"
#
# MINIMAX example:
#   [embeddings]
#   provider    = "minimax"
#   api_key_env = "MINIMAX_API_KEY"
#   base_url    = "https://api.minimax.io/v1"
#   model       = "embo-01"

[notify]
default_channel = "cli"

# ─────────────────────────────────────────────
# MCP (Model Context Protocol) — Issue #9
# ─────────────────────────────────────────────
# Requires: pip install loom[mcp]
#
# Each [[mcp.servers]] entry starts an external MCP server subprocess
# and imports its tools into the Loom session registry at startup.
# Tools are prefixed with the server name: "filesystem:list_files"
#
# trust_level controls what Loom trust tier the imported tools receive:
#   safe    → auto-executed (SAFE tier)
#   guarded → confirmation required (GUARDED tier)

# ── Example: MCP filesystem server ───────────────────────────────────────────
# [[mcp.servers]]
# name        = "filesystem"
# command     = "npx"
# args        = ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
# trust_level = "safe"

# ── Example: MCP git server ───────────────────────────────────────────────────
# [[mcp.servers]]
# name        = "git"
# command     = "uvx"
# args        = ["mcp-server-git", "--repository", "."]
# trust_level = "guarded"
